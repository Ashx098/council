{
  "manifest_version": 3,
  "name": "Council",
  "version": "0.1.0",
  "description": "Sync ChatGPT conversations with Council Hub",
"permissions": [
"activeTab",
"storage",
    "scripting",
    "alarms"
],
  "host_permissions": [
    "http://localhost:7337/*",
    "http://127.0.0.1:7337/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "src/lib/thread_id.js",
        "src/lib/dom_extract.js",
        "src/lib/format_digest.js",
        "src/content_script.js"
      ],
      "css": ["src/content_styles.css"]
    }
  ],
  "action": {
    "default_popup": "src/ui/panel.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
